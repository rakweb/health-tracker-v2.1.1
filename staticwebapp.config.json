{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/*.css",
      "/*.js",
      "/*.png",
      "/*.jpg",
      "/*.jpeg",
      "/*.svg",
      "/*.ico",
      "/icons/*"
    ]
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "routes": [
    {
      "route": "/service-worker.js",
      "headers": {
        "Cache-Control": "no-cache"
      }
    }
  ]
}